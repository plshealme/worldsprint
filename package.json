{
  "name": "wordsprint",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "words:json": "node --experimental-strip-types scripts/convert-redbook-words.ts",
    "words:build-clean": "node --experimental-strip-types scripts/build-clean-redbook-words.ts",
    "words:build-enriched": "node --experimental-strip-types scripts/build-enriched-redbook-words.ts",
    "words:audit": "node --experimental-strip-types scripts/audit-redbook-words.ts",
    "practice:check": "node --experimental-strip-types scripts/check-practice-questions.ts",
    "words:validate": "node --experimental-strip-types scripts/import-redbook-words.ts --dry-run",
    "words:import": "node --experimental-strip-types scripts/import-redbook-words.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "clsx": "2.1.1",
    "lucide-react": "1.21.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.1",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2",
    "xlsx": "^0.18.5"
  }
}
